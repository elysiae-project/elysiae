<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>app.elysiae.Elysiae</id>
    <branding>
        <color type="primary" scheme_preference="light">#4bcaf4</color>
        <color type="primary" scheme_preference="dark">#473a7c</color>    
    </branding>
    <developer id="app.elysiae">
        <name>Shob3r &amp; ChakornK </name>
    </developer>
    <name>Elysiae</name>
    <summary>Unofficial "Anime Game" Launcher for Linux</summary>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>BSD-3-Clause</project_license>
    <url type="homepage">https://github.com/elysiae-project/elysiae</url>
    <url type="bugtracker">https://github.com/elysiae-project/elysiae/issues</url>
    <description>
        <p>This app is in Alpha! Please use with caution, and expect bugs and missing features</p>
        <p>Elysiae is a Universal "Anime Game" for x64 Linux hosts using Wine and DXVK.</p>
        <p>The application meant to replace the individual launchers created by an-anime-team, as
            work on a unified launcher has stalled</p>
    </description>
    <categories>
        <category>Game</category>
        <category>LauncherStore</category>
    </categories>
    <requires>
        <control>keyboard</control>
        <control>pointing</control>
        <display_length compare="ge">768</display_length>
    </requires>
    <launchable type="desktop-id">app.elysiae.Elysiae.desktop</launchable>
    <!--
    The Flathub styling guide says that I should set the rating while also keeping in mind what this application downloads. 
    However, the projects I'm trying to replace (from an-anime-team) do not. I will do the same, because the content that Elysiae
    downloads is can't really define a global rating for the application, since each game contains different (albeit somewhat similar) 
    subject matter.
        -->
    <content_rating type="oars-1.1">
        <content_attribute id="violence-fantasy">moderate</content_attribute>
        <content_attribute id="violence-bloodshed">mild</content_attribute>
        <content_attribute id="drugs-alcohol">mild</content_attribute>
        <content_attribute id="sex-themes">mild</content_attribute>
        <content_attribute id="language-profanity">mild</content_attribute>
        <content_attribute id="language-humor">mild</content_attribute>
        <content_attribute id="social-chat">moderate</content_attribute>
        <content_attribute id="social-info">moderate</content_attribute>
        <content_attribute id="social-audio">moderate</content_attribute>
        <content_attribute id="money-purchasing">intense</content_attribute>
        <content_attribute id="money-gambling">mild</content_attribute>
    </content_rating>
</component>
