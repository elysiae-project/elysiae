<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>app.elysiae.Elysiae</id>
  <name>Elysiae</name>
  <summary>Universal "Anime Game" Launcher</summary>
  <developer id="app.elysiae">
    <name>The Elysiae Project</name>
  </developer>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>BSD-3-Clause</project_license>
  <description>
    <p>Elysiae is a universal "Anime Game" launcher for Linux hosts</p>
    <p>Elysiae is built to be efficient, have a beautiful UI, use modern/cutting-edge wine tooling, and serve as a replacement for the aag launchers and other Linux-based launchers/</p>
  </description>
  <launchable type="desktop-id">app.elysiae.Elysiae.desktop</launchable>
  <categories>
    <category>Game</category>
    <category>LauncherStore</category>
  </categories>
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>gamepad</control>    <!--No clue if this works, I don't own a controller to be able to test it with-->
    <control>touch</control>
  </supports>
  <requires>
    <display_length compare="ge">1279</display_length>
  </requires>
  <url type="homepage">https://elysiae.app</url>
  <url type="bugtracker">https://github.com/elysiae-project/elysiae/issues</url>
  <branding>
    <color type="primary" scheme_preference="light">#4bcaf4</color>
    <color type="primary" scheme_preference="dark">#473a7c</color>
  </branding>
