<?xml version="1.0" encoding="UTF-8"?>
<!-- Copyright 2026 The Elysiae Project -->
<component type="desktop-application">
    <name>Elysiae</name>
    <id>app.elysiae.Elysiae</id>

    <developer id="app.elysiae">
        <name>Shob3r</name>
        <name>ChakornK</name>
        <name>Elysiae Contributors</name>
    </developer>

    <summary>Universal "Anime Game" Launcher</summary>
    <description>
        <p>This app is in early development! Expect bugs and missing/unpolished features. Please report any bugs on our GitHub repository</p>
        <p>Elysiae is a universal "Anime Game" launcher for Linux hosts</p>
        <p>Elysiae is built to be efficient, have a beautiful UI, use modern/cutting-edge wine tooling, and serve as a replacement for the aag launchers and twintail/</p>
    </description>

    <project_license>BSD-3-Clause</project_license>
    <metadata_license>CC0-1.0</metadata_license>

    <categories>
        <category>Game</category>
        <category>LauncherStore</category>
    </categories>

    <url type="homepage">https://elysiae.app</url>
    <url type="bugtracker">https://github.com/elysiae-project/elysiae/issues</url>

    <requires>
        <control>keyboard</control>
        <control>pointing</control>
        <control>gamepad</control>
        <control>touch</control>
        <display_length compare="ge">1279</display_length> <!--TODO: Handheld (i.e. Steam Deck, ROG Ally, etc.) support-->
    </requires>

    <launchable type="desktop-id">app.elysiae.Elysiae.desktop</launchable>
    <provides>
        <id>Elysiae.desktop</id>
    </provides>

    <branding>
        <color type="primary" scheme_preference="light">#4bcaf4</color>
        <color type="primary" scheme_preference="dark">#473a7c</color>    
    </branding>

