{
	"$schema": "https://json.schemastore.org/prettierrc",
	"tabWidth": 2,
	"useTabs": true,
	"trailingComma": "all",
	"semi": true,
	"singleQuote": false,
	"endOfLine": "lf",
	"arrowParens": "always",
	"bracketSameLine": true,
	"plugins": ["prettier-plugin-sort-imports", "prettier-plugin-tailwindcss"],
	"tailwindStylesheet": "./src/App.css"
}
