<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>net.shob3r.yoohoo</id>
    <developer id="net.shob3r">
        <name>Andrew Pinter</name>
    </developer>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>BSD-3-Clause</project_license>
    <name>Yoohoo!</name>
    <summary>Universal Hoyoverse Game Launcher for Linux</summary>
    <url type="homepage">https://github.com/shob3r/yoohoo</url>
    <description>
        <p>Yoohoo! is a Universal Hoyoverse Game Launcher for x64 Linux hosts using Wine and DXVK.</p>
        <p>Yoohoo! is meant to replace the launchers from an-anime-team, as work on a unified launcher appears to have stalled</p>
        <p>This app works with the following games:</p>
        <ul>
            <li>Honkai Impact 3rd</li>
            <li>Genshin Impact</li>
            <li>Honkai: Star Rail</li>
            <li>Zenless Zone Zero</li>
        </ul>
    </description>
    <categories>
        <category>Game</category>
        <category>LauncherStore</category>
    </categories>
    <requires>
        <control>keyboard</control>
        <control>pointing</control>
        <display_length compare="ge">768</display_length>
    </requires>
</component>