{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "yoohoo",
	"version": "0.1.0",
	"identifier": "dev.shob3r.yoohoo",
	"build": {
		"beforeDevCommand": "yarn dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "yarn build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "yoohoo",
				"width": 1200,
				"height": 700,
				"minHeight": 700,
				"minWidth": 1200,
				"decorations": false,
				"shadow": true,
				"transparent": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["deb"],
		"linux": {
			"deb": {
				"files": {
					"/usr/share/metainfo/io.shob3r.yoohoo.metainfo.xml": "../io.shob3r.yoohoo.metainfo.xml"
				}
			}
		}
	}
}
